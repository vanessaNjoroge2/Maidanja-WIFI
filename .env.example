# ============================================================
# Maidanja WiFi — Configuration Template
# Copy to .env and fill in your ACTUAL values
# ============================================================

# ════════════════════════════════════════════════════════════
# ✅ PRE-PAYMENT CHECKLIST
# ════════════════════════════════════════════════════════════
# Before M-Pesa payments will work, complete these steps:
#
# [ ] 1. Go to https://developer.safaricom.co.ke
# [ ] 2. Sign up for Daraja API access (free, takes 2-3 minutes)
# [ ] 3. Create an "app" in the My Apps section  
# [ ] 4. Copy your Consumer Key → MPESA_CONSUMER_KEY below
# [ ] 5. Copy your Consumer Secret → MPESA_CONSUMER_SECRET below
# [ ] 6. Copy your Passkey → MPESA_PASSKEY below
# [ ] 7. Use MPESA_SHORTCODE=174379 (Safaricom's sandbox code)
# [ ] 8. Install ngrok for local development: https://ngrok.com/download
# [ ] 9. Run: ngrok http 3000
# [ ] 10. Copy ngrok https URL → MPESA_CALLBACK_URL below
# [ ] 11. Restart your backend: npm run dev
#
# Without these, payments will fail with 502 errors!
# ════════════════════════════════════════════════════════════

# ════════════════════════════════════════════════════════════
# SERVER & ENVIRONMENT
# ════════════════════════════════════════════════════════════
PORT=3000
NODE_ENV=development

# Production — set this to your exact Vercel frontend URL
CORS_ORIGIN=https://maidanja-wifi.vercel.app
# Development — comma-separated list of allowed origins
# CORS_ORIGIN=http://localhost:5000,http://localhost:3000

# ════════════════════════════════════════════════════════════
# DATABASE (PostgreSQL)
# ════════════════════════════════════════════════════════════
DB_HOST=localhost
DB_PORT=5432
DB_NAME=maidanja_wifi
DB_USER=postgres
DB_PASSWORD=your_postgres_password_here

# ════════════════════════════════════════════════════════════
# JWT (Authentication Token Security)
# ════════════════════════════════════════════════════════════
# Generate a strong secret:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change_this_to_a_long_random_string_at_least_32_chars
JWT_EXPIRES_IN=7d

# ════════════════════════════════════════════════════════════
# M-PESA INTEGRATION (Safaricom Daraja API)
# ════════════════════════════════════════════════════════════

# MPESA_CONSUMER_KEY
# ──────────────────────────────────────────────────────────
# Where to find: https://developer.safaricom.co.ke
#   1. Log in → My Apps
#   2. Click your app → View Details
#   3. Copy "Consumer Key"
#
MPESA_CONSUMER_KEY=your_daraja_consumer_key

# MPESA_CONSUMER_SECRET  
# ──────────────────────────────────────────────────────────
# Where to find: Same location as Consumer Key
#   1. Log in → My Apps → Your App → View Details
#   2. Copy "Consumer Secret"
#
MPESA_CONSUMER_SECRET=your_daraja_consumer_secret

# MPESA_SHORTCODE
# ──────────────────────────────────────────────────────────
# For SANDBOX/Development: Use 174379 (Safaricom's test code)
# For PRODUCTION: Your actual business shortcode (6 digits)
#
MPESA_SHORTCODE=174379

# MPESA_PASSKEY
# ──────────────────────────────────────────────────────────
# Where to find: https://developer.safaricom.co.ke
#   1. Log in → My Apps → Your App
#   2. Scroll down to "Lipa Na M-Pesa Online"
#   3. Copy the exact "Passkey" value
#
# CRITICAL: This must be copied EXACTLY (case-sensitive)
#
MPESA_PASSKEY=your_lipa_na_mpesa_passkey

# MPESA_CALLBACK_URL (CRITICAL FOR PAYMENTS!)
# ──────────────────────────────────────────────────────────
# This is where Safaricom sends payment status updates.
# It MUST be publicly accessible (not localhost:3000)
#
# FOR LOCAL DEVELOPMENT WITH NGROK:
#   1. Install: https://ngrok.com/download
#   2. Run in another terminal: ngrok http 3000
#   3. Copy the https URL that appears (e.g., https://abc123.ngrok.io)
#   4. Set to: https://abc123.ngrok.io/api/payments/callback
#   5. Every time ngrok restarts, you get a new URL — update this!
#   6. (Optional) Get ngrok Pro for static URLs
#
# FOR PRODUCTION:
#   Set to your real domain: https://yourdomain.com/api/payments/callback
#   Must be HTTPS in production
#
# WITHOUT THIS: Payments will fail with 502 Bad Gateway
#
MPESA_CALLBACK_URL=http://localhost:3000/api/payments/callback

# MPESA_ENVIRONMENT
# ──────────────────────────────────────────────────────────
# Values: "sandbox" (testing) or "production" (live)
# Use sandbox with credentials from Daraja API
# Use production with real business credentials
#
MPESA_ENVIRONMENT=sandbox

# ════════════════════════════════════════════════════════════
# MIKROTIK HOTSPOT INTEGRATION (Optional)
# ════════════════════════════════════════════════════════════

# MIKROTIK_MODE: simulation or real
# Use "simulation" for development
# Use "real" to connect to actual MikroTik router
MIKROTIK_MODE=simulation

# Real MikroTik API Settings (only if MIKROTIK_MODE=real)
MIKROTIK_HOST=192.168.1.1
MIKROTIK_USER=admin
MIKROTIK_PASSWORD=your_mikrotik_password
HOTSPOT_PROFILE=default

# Hotspot Settings
HOTSPOT_SSID=Maidanja
HOTSPOT_ADDRESS=192.168.100.1
MAX_CONCURRENT_SESSIONS=1000

# ════════════════════════════════════════════════════════════
# TROUBLESHOOTING PAYMENT ERRORS
# ════════════════════════════════════════════════════════════
#
# ❌ Error: "502 Bad Gateway" or "Failed to load resource"
# → Check if MPESA_CALLBACK_URL is valid
# → Make sure ngrok tunnel is running: ngrok http 3000
# → Verify URL starts with https://
# → Check server logs: npm run dev
#
# ❌ Error: "M-Pesa authentication failed"
# → Verify Consumer Key and Secret from Daraja API
# → Make sure MPESA_ENVIRONMENT matches your credentials
# → Keys are case-sensitive, copy exactly
#
# ❌ Error: "Valid package_id required"
# → This is normal validation, ensure package exists in database
# → Run: node backend/seed-database.js
#
# ❌ Error: "Cannot reach M-Pesa service"
# → Check internet connection
# → Verify MPESA_ENVIRONMENT is set correctly
# → Try from different network
#
# ❌ Error: "SCRAM-SERVER-FIRST-MESSAGE"
# → Database connection failed
# → Check DB_PASSWORD is correct
# → Verify PostgreSQL is running
#
# ✅ HOW TO DEBUG:
# 1. Run: npm run dev
# 2. Watch console for M-Pesa logs (🔐 token, 📱 STK, ✅ success)
# 3. Open browser DevTools (F12) → Network tab
# 4. Look for /api/payments/initiate request
# 5. Check Response tab for error details
# 6. Check browser Console for JavaScript errors
# 7. Check server console for backend errors

